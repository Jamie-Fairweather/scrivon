# Local Tauri builds — loaded by scripts/tauri-cli.mjs (the stock Tauri CLI does not read .env).

# Option 1: path to the private key file (recommended)
TAURI_SIGNING_PRIVATE_KEY_PATH=src-tauri/.updater/scrivon

# Option 2: paste the full private key contents instead
# TAURI_SIGNING_PRIVATE_KEY=

# Only if your key has a password
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
