    "type": "module",
    "scripts": {
        "dev": "next dev",
        "prebuild": "node scripts/generate-examples.mjs",
        "build": "node scripts/next-build.mjs",
        "postbuild": "node scripts/generate-licenses.mjs",
        "start": "next start",
        "tauri": "node scripts/tauri-cli.mjs",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{ts,tsx,md,mjs,json,css}\"",
        "generate:examples": "node scripts/generate-examples.mjs",
        "generate:licenses": "node scripts/generate-licenses.mjs",
        "release": "semantic-release",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{md,json,css}": [
            "prettier --write"
        ]
